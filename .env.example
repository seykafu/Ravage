# Supabase credentials. Required for cloud-synced save slots.
# Without these, the game runs in offline mode (saves to localStorage only).
#
# Vite exposes any var prefixed with VITE_ to the client at build time.
# DO NOT put your service_role key here — only the anon (public) key.
#
# Find these in your Supabase project at:
#   Project Settings → API → Project URL / anon public key

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
